# Application Settings
PORT=10000
ENV=production
ALLOWED_ORIGINS=http://localhost:3000

# Database Settings
# On Render, this will be automatically provided if using a Blueprint, or manual DATABASE_URL
DATABASE_URL=postgres://user:password@host:5432/dbname

# Redis & Queue Settings (Optional for Render)
# Set to "none" or leave empty to disable Redis and Background Workers.
REDIS_URL=none
REDIS_PASS=
REDIS_DB=0

# Frontend URL for links in emails
FRONTEND_URL=http://localhost:3000

# External Integrations (Optional)
GOOGLE_SCRIPT_URL=
